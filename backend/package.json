    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "ts-node src/db/seed.ts",
    "logs": "docker compose -f ../docker-compose.yml logs --tail 100 app"
  },
  "keywords": [],
